# IBKR Connection Settings
# No API keys needed — authentication is handled by logging into TWS or IB Gateway.
#
# Copy this file to .env and adjust if needed:
#   cp .env.example .env
#
# ── Connection ───────────────────────────────────────────────────────────────
# TWS must be running and logged in before you run live_trader.py.
# Enable API in TWS: File > Global Configuration > API > Settings
#   ☑ Enable ActiveX and Socket Clients
#   ☑ Allow connections from localhost only

IBKR_HOST=127.0.0.1

# Port depends on which platform and mode you're using:
#   TWS paper trading:      7497   ← default
#   TWS live trading:       7496
#   IB Gateway paper:       4002
#   IB Gateway live:        4001
IBKR_PORT=7497

# Client ID — must be unique if you have multiple scripts connected simultaneously
IBKR_CLIENT_ID=1

# ── Trading mode ─────────────────────────────────────────────────────────────
# Set to "false" to trade with real money (uses port 7496 by default).
# Default is "true" (paper trading) — safe to leave until you're ready.
IBKR_PAPER=true

# ── Currency ──────────────────────────────────────────────────────────────────
# USD/CAD exchange rate used only if IBKR does not report your portfolio value
# in USD directly (rare for CAD-based accounts). Update quarterly.
USD_CAD_RATE=1.38

# ── Email notifications ───────────────────────────────────────────────────────
# After each quarterly rebalance, the full log (including TSX manual trades)
# is emailed to EMAIL_TO. Requires a Gmail account with an App Password.
#
# Setup:
#   1. Go to myaccount.google.com → Security → 2-Step Verification → App passwords
#   2. Create an App Password for "Mail"
#   3. Paste the 16-character password below (spaces are fine)
#
EMAIL_FROM=your_gmail@gmail.com
EMAIL_TO=your_email@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
